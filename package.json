{
  "name": "yura-scheduler-v3",
  "version": "3.0.0",
  "description": "Enterprise-grade figure skating lesson scheduling platform with advanced performance optimizations, real-time analytics, and comprehensive student management",
  "private": true,
  "author": {
    "name": "Yura Scheduler Team",
    "email": "contact@yurascheduler.com"
  },
  "keywords": [
    "figure-skating",
    "scheduling",
    "lesson-management",
    "student-management",
    "calendar",
    "payments",
    "nextjs",
    "react",
    "typescript",
    "trpc",
    "prisma",
    "performance-optimized",
    "enterprise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/yura-scheduler-v3.git"
  },
  "homepage": "https://github.com/your-username/yura-scheduler-v3#readme",
  "bugs": {
    "url": "https://github.com/your-username/yura-scheduler-v3/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check ./src",
    "lint:fix": "biome check --apply ./src",
    "format": "biome format --write ./src",
    "analyze": "cross-env ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen localhost:3000",
    "test:all": "npm run test:run && npm run test:e2e",
    "security:audit": "node scripts/security-audit.js",
    "security:fix": "pnpm audit --fix",
    "prisma:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "mobile:test": "node scripts/validate-touch-targets.js",
    "dev:mobile": "next dev --port 3000 --hostname 0.0.0.0",
    "docs:dev": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy",
    "docker:dev": "docker-compose up",
    "docker:build": "docker-compose build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "docker:studio": "docker-compose --profile studio up prisma-studio",
    "docker:db": "docker-compose up db redis",
    "docker:shell": "docker-compose exec app sh"
  },
  "dependencies": {
    "@executeautomation/playwright-mcp-server": "^1.0.6",
    "@hookform/resolvers": "^5.1.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.67.2",
    "@tanstack/react-virtual": "^3.13.10",
    "@toast-ui/react-calendar": "^2.1.3",
    "@trpc/client": "^11.0.0-rc.824",
    "@trpc/next": "^11.0.0-rc.824",
    "@trpc/react-query": "^11.0.0-rc.824",
    "@trpc/server": "^11.4.3",
    "@types/ioredis": "^5.0.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "critters": "^0.0.25",
    "date-fns": "4.1.0",
    "geist": "^1.4.2",
    "googleapis": "^150.0.1",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.522.0",
    "luxon": "^3.6.1",
    "next": "15.3.4",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-big-calendar": "^1.18.0",
    "react-day-picker": "^9.6.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "redis": "^5.5.6",
    "resend": "^4.1.2",
    "sonner": "^2.0.1",
    "superjson": "^2.2.2",
    "swagger-ui-react": "^5.29.4",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "trpc-openapi": "^1.2.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^9.9.0",
    "@next/bundle-analyzer": "^15.2.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.11",
    "@types/react-big-calendar": "^1.16.1",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "msw": "^2.10.4",
    "msw-trpc": "^2.0.1",
    "node-mock-http": "^1.0.2",
    "postcss": "^8.5.3",
    "prisma": "^6.4.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    },
    "dompurify": ">=3.2.4"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.2.4"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20.15.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write"
    ],
    "package.json": [
      "biome format --write"
    ]
  }
}
