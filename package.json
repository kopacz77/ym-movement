{
  "name": "yura-scheduler-v3",
  "version": "3.0.0",
  "description": "Enterprise-grade figure skating lesson scheduling platform with advanced performance optimizations, real-time analytics, and comprehensive student management",
  "private": true,
  "author": {
    "name": "Yura Scheduler Team",
    "email": "contact@yurascheduler.com"
  },
  "keywords": [
    "figure-skating",
    "scheduling",
    "lesson-management",
    "student-management",
    "calendar",
    "payments",
    "nextjs",
    "react",
    "typescript",
    "trpc",
    "prisma",
    "performance-optimized",
    "enterprise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/yura-scheduler-v3.git"
  },
  "homepage": "https://github.com/your-username/yura-scheduler-v3#readme",
  "bugs": {
    "url": "https://github.com/your-username/yura-scheduler-v3/issues"
  },
  "scripts": {
    "dev": "next dev -p 3100 --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write --unsafe ./src",
    "format": "biome format --write ./src",
    "analyze": "cross-env ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen localhost:3100",
    "test:all": "npm run test:run && npm run test:e2e",
    "security:audit": "node scripts/security-audit.js",
    "security:fix": "pnpm audit --fix",
    "prisma:migrate": "prisma migrate deploy",
    "migrate:coach-data": "tsx scripts/migrate-coach-data.ts",
    "migrate:lesson-types": "tsx scripts/migrate-lesson-types.ts",
    "migrate:fix-prices": "tsx scripts/fix-lesson-prices.ts",
    "test:bot-protection": "tsx scripts/test-bot-protection.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "mobile:test": "node scripts/validate-touch-targets.js",
    "dev:mobile": "next dev --port 3100 --hostname 0.0.0.0",
    "docs:dev": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy",
    "docker:dev": "docker-compose up",
    "docker:build": "docker-compose build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "docker:studio": "docker-compose --profile studio up prisma-studio",
    "docker:db": "docker-compose up db redis",
    "docker:shell": "docker-compose exec app sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.3.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.12",
    "@trpc/client": "^11.8.1",
    "@trpc/next": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "4.1.0",
    "geist": "^1.5.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.522.0",
    "luxon": "^3.7.2",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "recharts": "^2.15.4",
    "redis": "^5.10.0",
    "resend": "^4.8.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "swagger-ui-react": "^5.30.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "trpc-openapi": "^1.2.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^9.9.0",
    "@next/bundle-analyzer": "^15.5.7",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "msw-trpc": "^2.0.1",
    "node-mock-http": "^1.0.4",
    "postcss": "^8.5.6",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "react": "^19.2.3",
      "react-dom": "^19.2.3"
    },
    "dompurify": ">=3.2.4"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.2.4",
      "qs": ">=6.14.2",
      "body-parser": ">=1.20.3",
      "glob": ">=11.0.1",
      "preact": ">=10.28.2",
      "h3": ">=1.15.5",
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "axios": ">=1.13.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": ">=10.2.1",
      "ajv": ">=8.18.0",
      "rollup": ">=4.59.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20.15.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write"
    ],
    "package.json": [
      "biome format --write"
    ]
  }
}
