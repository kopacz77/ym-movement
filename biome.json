{
    "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
    "organizeImports": {
      "enabled": true
    },
    "linter": {
      "enabled": true,
      "rules": {
        "recommended": true,
        "correctness": {
          "noUnusedVariables": "error",
          "useExhaustiveDependencies": "error",
          "noConstantCondition": "error"
        },
        "suspicious": {
          "noExplicitAny": "warn",
          "noEmptyInterface": "error",
          "noConsoleLog": "off",
          "noRedundantUseStrict": "error"
        },
        "style": {
          "noNegationElse": "error",
          "useBlockStatements": "error",
          "useShorthandArrayType": "error",
          "useTemplate": "error"
        },
        "nursery": {}
      }
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "formatWithErrors": false,
      "include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.json"]
    },
    "javascript": {
      "formatter": {
        "quoteStyle": "double",
        "semicolons": "always"
      }
    },
    "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
    },
    "files": {
      "ignore": [
        "node_modules",
        ".next",
        "dist",
        "build",
        "public",
        "**/*.d.ts",
        "coverage",
        "pnpm-lock.yaml"
      ]
    }
  }