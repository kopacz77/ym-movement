generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DefaultPricing {
  id                 String   @id
  privateLessonPrice Float    @default(75)
  groupLessonPrice   Float    @default(45)
  choreographyPrice  Float    @default(90)
  competitionPrice   Float    @default(95)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
}

model Lesson {
  id                    String        @id
  studentId             String
  rinkId                String
  startTime             DateTime
  endTime               DateTime
  duration              Int
  type                  LessonType    @default(PRIVATE)
  area                  RinkArea      @default(MAIN_RINK)
  status                LessonStatus  @default(SCHEDULED)
  cancellationReason    String?
  cancellationTime      DateTime?
  notes                 String?
  price                 Float
  timeSlotId            String?
  googleCalendarEventId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime
  Rink                  Rink          @relation(fields: [rinkId], references: [id])
  Student               Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  RinkTimeSlot          RinkTimeSlot? @relation(fields: [timeSlotId], references: [id])
  Payment               Payment?

  @@index([endTime])
  @@index([rinkId])
  @@index([rinkId, startTime])
  @@index([startTime])
  @@index([status])
  @@index([studentId])
  @@index([studentId, startTime])
  @@index([timeSlotId])
}

model Notification {
  id        String   @id
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Payment {
  id             String        @id
  lessonId       String        @unique
  studentId      String
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  referenceCode  String        @unique
  verifiedBy     String?
  verifiedAt     DateTime?
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  lesson_date    DateTime
  Lesson         Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  Student        Student       @relation(fields: [studentId], references: [id])

  @@index([createdAt])
  @@index([lesson_date])
  @@index([referenceCode])
  @@index([status])
  @@index([status, lesson_date])
  @@index([studentId])
  @@index([studentId, status])
}

model RecurringPattern {
  id          String   @id
  rinkId      String
  daysOfWeek  Int[]
  startDate   DateTime
  endDate     DateTime
  startTime   String
  duration    Int
  maxStudents Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Rink        Rink     @relation(fields: [rinkId], references: [id], onDelete: Cascade)

  @@index([rinkId])
}

model Rink {
  id               String             @id
  name             String             @unique
  timezone         String
  address          String
  maxCapacity      Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Lesson           Lesson[]
  RecurringPattern RecurringPattern[]
  RinkTimeSlot     RinkTimeSlot[]
}

model RinkTimeSlot {
  id          String   @id
  rinkId      String
  startTime   DateTime
  endTime     DateTime
  maxStudents Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  recurringId String?
  Lesson      Lesson[]
  Rink        Rink     @relation(fields: [rinkId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([recurringId])
  @@index([rinkId])
  @@index([rinkId, isActive])
  @@index([rinkId, startTime])
  @@index([startTime])
}

model Settings {
  id        String   @id
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Student {
  id                   String        @id
  userId               String        @unique
  phone                String?
  maxLessonsPerWeek    Int           @default(3)
  notes                String?
  level                Level         @default(PRELIMINARY)
  emergencyContact     Json?
  isApproved           Boolean       @default(false)
  approvedAt           DateTime?
  approvedById         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime
  parentConsent        Boolean       @default(false)
  customPricingEnabled Boolean       @default(false)
  privateLessonPrice   Float?
  groupLessonPrice     Float?
  choreographyPrice    Float?
  competitionPrepPrice Float?
  Lesson               Lesson[]
  Payment              Payment[]
  User                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  StudentNote          StudentNote[]

  @@index([createdAt])
  @@index([isApproved])
  @@index([level])
}

model StudentNote {
  id          String   @id
  studentId   String
  content     String
  type        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [createdById], references: [id])
  Student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([studentId])
}

model User {
  id                 String               @id
  email              String               @unique
  name               String?
  password           String?
  role               Role                 @default(STUDENT)
  emailVerified      DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Notification       Notification[]
  PasswordResetToken PasswordResetToken[]
  Student            Student?
  StudentNote        StudentNote[]

  @@index([createdAt])
  @@index([emailVerified])
  @@index([role])
}

enum LessonStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum LessonType {
  PRIVATE
  GROUP
  CHOREOGRAPHY
  COMPETITION_PREP
}

enum Level {
  PRE_PRELIMINARY
  PRELIMINARY
  PRE_JUVENILE
  JUVENILE
  INTERMEDIATE
  NOVICE
  JUNIOR
  SENIOR
}

enum PaymentMethod {
  VENMO
  ZELLE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RinkArea {
  MAIN_RINK
  PRACTICE_RINK
  DANCE_STUDIO
}

enum Role {
  ADMIN
  COACH
  STUDENT
}
