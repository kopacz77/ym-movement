generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DefaultPricing {
  id                 String   @id @default(cuid())
  privateLessonPrice Float    @default(75)
  groupLessonPrice   Float    @default(45)
  choreographyPrice  Float    @default(90)
  competitionPrice   Float    @default(95)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
}

model Lesson {
  id                    String        @id @default(cuid())
  studentId             String
  rinkId                String
  startTime             DateTime
  endTime               DateTime
  duration              Int
  type                  LessonType    @default(PRIVATE)
  area                  RinkArea      @default(MAIN_RINK)
  status                LessonStatus  @default(SCHEDULED)
  cancellationReason    String?
  cancellationTime      DateTime?
  notes                 String?
  price                 Float
  timeSlotId            String?
  coachId               String?
  googleCalendarEventId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  Coach                 Coach?        @relation(fields: [coachId], references: [id], onDelete: SetNull)
  Rink                  Rink          @relation(fields: [rinkId], references: [id])
  Student               Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  RinkTimeSlot          RinkTimeSlot? @relation(fields: [timeSlotId], references: [id])
  Payment               Payment?

  @@index([coachId])
  @@index([endTime])
  @@index([rinkId])
  @@index([rinkId, startTime])
  @@index([startTime])
  @@index([status])
  @@index([studentId])
  @@index([studentId, startTime])
  @@index([timeSlotId])
  // Performance optimization indexes
  @@index([timeSlotId, status])
  @@index([studentId, status, startTime])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@index([userId, isRead, createdAt])
}

model PendingEmailNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String    @default("SCHEDULE_CHANGE")
  lessonId  String?
  metadata  Json?
  createdAt DateTime  @default(now())
  sentAt    DateTime?
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([sentAt])
  @@index([userId, sentAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([email, success, createdAt])
}

model Payment {
  id             String        @id @default(cuid())
  lessonId       String        @unique
  studentId      String
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  referenceCode  String        @unique
  verifiedBy     String?
  verifiedAt     DateTime?
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lesson_date    DateTime
  Lesson         Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  Student        Student       @relation(fields: [studentId], references: [id])

  @@index([createdAt])
  @@index([lesson_date])
  @@index([referenceCode])
  @@index([status])
  @@index([status, lesson_date])
  @@index([studentId])
  @@index([studentId, status])
}

model RecurringPattern {
  id          String   @id @default(cuid())
  rinkId      String
  daysOfWeek  Int[]
  startDate   DateTime
  endDate     DateTime
  startTime   String
  duration    Int
  maxStudents Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Rink        Rink     @relation(fields: [rinkId], references: [id], onDelete: Cascade)

  @@index([rinkId])
}

model Rink {
  id               String             @id @default(cuid())
  name             String             @unique
  timezone         String
  address          String
  maxCapacity      Int?
  isVirtual        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  Lesson           Lesson[]
  RecurringPattern RecurringPattern[]
  RinkTimeSlot     RinkTimeSlot[]
  ProposedTimeSlot ProposedTimeSlot[]
}

model RinkTimeSlot {
  id          String   @id @default(cuid())
  rinkId      String
  coachId     String?
  startTime   DateTime
  endTime     DateTime
  maxStudents Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recurringId String?
  Coach       Coach?   @relation(fields: [coachId], references: [id], onDelete: SetNull)
  Lesson      Lesson[]
  Rink        Rink     @relation(fields: [rinkId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([isActive])
  @@index([recurringId])
  @@index([rinkId])
  @@index([rinkId, isActive])
  @@index([rinkId, startTime])
  @@index([startTime])
  // Performance optimization indexes
  @@index([rinkId, isActive, startTime])
  @@index([rinkId, startTime, endTime])
  @@index([isActive, startTime, endTime])
  @@index([startTime, endTime])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id                   String        @id @default(cuid())
  userId               String        @unique
  phone                String?
  dateOfBirth          String?
  maxLessonsPerWeek    Int           @default(3)
  notes                String?
  level                Level         @default(PRELIMINARY)
  emergencyContact     Json?
  isApproved           Boolean       @default(false)
  approvedAt           DateTime?
  approvedById         String?
  isActive             Boolean       @default(true)
  deactivatedAt        DateTime?
  deactivatedById      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  parentConsent        Boolean       @default(false)
  customPricingEnabled Boolean       @default(false)
  privateLessonPrice   Float?
  groupLessonPrice     Float?
  choreographyPrice    Float?
  competitionPrepPrice Float?
  Lesson               Lesson[]
  Payment              Payment[]
  User                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  StudentNote          StudentNote[]
  CoachStudent         CoachStudent[]

  @@index([createdAt])
  @@index([isApproved])
  @@index([level])
}

model StudentNote {
  id          String   @id @default(cuid())
  studentId   String
  content     String
  type        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  User        User     @relation(fields: [createdById], references: [id])
  Student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([studentId])
}

model User {
  id                       String                     @id @default(cuid())
  email                    String                     @unique
  name                     String?
  password                 String?
  role                     Role                       @default(STUDENT)
  emailVerified            DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  BlockedDateRange         BlockedDateRange[]
  Notification             Notification[]
  PendingEmailNotification PendingEmailNotification[]
  PasswordResetToken       PasswordResetToken[]
  Coach                    Coach?
  Student                  Student?
  StudentNote              StudentNote[]

  @@index([createdAt])
  @@index([emailVerified])
  @@index([role])
  @@index([name])
}

enum LessonStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum LessonType {
  PRIVATE
  GROUP
  CHOREOGRAPHY
  COMPETITION_PREP
}

enum Level {
  PRE_PRELIMINARY
  PRELIMINARY
  PRE_JUVENILE
  JUVENILE
  INTERMEDIATE
  NOVICE
  JUNIOR
  SENIOR
}

enum PaymentMethod {
  VENMO
  ZELLE
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RinkArea {
  MAIN_RINK
  PRACTICE_RINK
  DANCE_STUDIO
}

enum Role {
  SUPER_ADMIN
  ADMIN
  COACH
  STUDENT
}

enum ProposalStatus {
  PENDING
  APPROVED
  DENIED
}

model BlockedDateRange {
  id          String          @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        BlockedDateType @default(TRAVEL)
  createdById String
  coachId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  Coach       Coach?          @relation(fields: [coachId], references: [id], onDelete: SetNull)
  User        User            @relation(fields: [createdById], references: [id])

  @@index([coachId])
  @@index([startDate])
  @@index([endDate])
  @@index([startDate, endDate])
  @@index([createdById])
  @@index([type, startDate, endDate])
}

enum BlockedDateType {
  TRAVEL
  COMPETITION
  OTHER
}

model Coach {
  id                   String            @id @default(cuid())
  userId               String            @unique
  bio                  String?
  photoUrl             String?
  skills               String[]
  certifications       String?
  yearsExperience      Int?
  isApproved           Boolean           @default(false)
  isActive             Boolean           @default(true)
  approvedAt           DateTime?
  approvedById         String?
  suspendedAt          DateTime?
  suspendedById        String?
  suspendedReason      String?
  privateLessonPrice   Float?
  groupLessonPrice     Float?
  choreographyPrice    Float?
  competitionPrepPrice Float?
  revenueSplitPercent  Float             @default(70)
  googleCalendarId     String?
  googleAccessToken    String?
  googleRefreshToken   String?
  googleTokenExpiresAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  User                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  Lesson               Lesson[]
  RinkTimeSlot         RinkTimeSlot[]
  BlockedDateRange     BlockedDateRange[]
  CoachStudent         CoachStudent[]
  ProposedTimeSlot     ProposedTimeSlot[]

  @@index([userId])
  @@index([isApproved, isActive])
}

model CoachStudent {
  id        String   @id @default(cuid())
  coachId   String
  studentId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  Coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  Student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([coachId, studentId])
  @@index([coachId])
  @@index([studentId])
}

model ProposedTimeSlot {
  id           String         @id @default(cuid())
  coachId      String
  rinkId       String
  startTime    DateTime
  endTime      DateTime
  maxStudents  Int            @default(1)
  status       ProposalStatus @default(PENDING)
  adminNotes   String?
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  Coach        Coach          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  Rink         Rink           @relation(fields: [rinkId], references: [id])

  @@index([coachId])
  @@index([status])
  @@index([coachId, status])
}
