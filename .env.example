# YM Movement Scheduler - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host.region.aws.neon.tech/database?sslmode=require"

# Authentication
NEXTAUTH_SECRET="generate-a-random-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"

# Google Calendar API
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID="your-calendar@gmail.com"
INSTRUCTOR_EMAIL="instructor@gmail.com"

# Optional: GitHub Personal Access Token for shadcn/ui MCP server
GITHUB_PERSONAL_ACCESS_TOKEN="ghp_your_token_here"

# Optional: Netlify deployment token
NETLIFY_AUTH_TOKEN="nfp_your_token_here"

# Optional: Redis URL (for caching)
REDIS_URL="redis://localhost:6379"
