#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged for staged files
npx lint-staged

# Run type checking
echo "📝 Type checking..."
pnpm type-check

# Run security audit
echo "🔒 Security audit..."
pnpm security:audit

echo "✅ Pre-commit checks completed successfully!"