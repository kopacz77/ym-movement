#!/usr/bin/env sh

echo "📝 Validating commit message format..."

# Detect if we're running in Windows/VS Code context
if [ -n "$WINDIR" ] || [ -n "$SYSTEMROOT" ] || echo "$PWD" | grep -q "wsl.localhost"; then
  echo "⚠️ Detected Windows/VS Code environment - skipping commitlint"
  echo "💡 For commit message validation, commit from within WSL terminal"
  echo "✅ Commit message validation completed (Windows mode)"
  exit 0
fi

# We're in a proper Unix environment, run validation
if command -v npx >/dev/null 2>&1; then
  npx commitlint --edit "$1"
else
  echo "⚠️ npx not found - skipping commit message validation"
fi

echo "✅ Commit message validation completed!"